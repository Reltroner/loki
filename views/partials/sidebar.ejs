<!-- views/partials/sidebar.ejs -->

<%
const role = user ? user.type : "M";

const styles = {
  T: "/css/style-admin.css",
  D: "/css/style-dosen.css",
  M: "/css/style-mahasiswa.css"
};

const logos = {
  T: "/images/burger_small_adm.png",
  D: "/images/burger_small_ds.png",
  M: "/images/burger_small_mhs.png"
};

const roleName = {
  T: "Admin",
  D: "Dosen",
  M: "Mahasiswa"
};

const courseLinks = {
  T: "/admin/coursesPlan",
  D: user ? `/dosen/${user.id}/courses` : "/",
  M: "/mahasiswa/"
};
%>

<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<title>Portal</title>

<link rel="stylesheet" href="<%= styles[role] %>">

<link rel="stylesheet" href="/public/css/table.css">
<link href="/vendor/sweetalert2.all.min.css"></link>
<script src="/vendor/sweetalert2.all.min.js"></script>

<link href='https://unpkg.com/boxicons@2.0.7/css/boxicons.min.css' rel='stylesheet'>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0-beta1/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="icon" href="/images/favicon.ico" type="image/x-icon">

<meta name="viewport" content="width=device-width, initial-scale=1.0">

</head>

<body>

<nav class="navbar container-fluid fixed-top">

<ul class="nav navbar-left">

<li class="nav-item">

<span class="logo-details">
<i class='bx bx-menu bx-md bx-fw'></i>
</span>

<a href="/" class="navbar-brand">

<img src="<%= logos[role] %>" width="30">

<span class="logo_name">Portal</span>

</a>

</li>

</ul>


<ul class="nav navbar-right">

<li class="nav-item">

<% if (user) { %>

<li class="welcome">
Welcome, <%= user.name %>
</li>

<% } %>

<a class="nav-link">

<i class='bx-fw bx bxs-user-circle bx-sm'></i>
<%= roleName[role] %>

</a>

</li>

</ul>

</nav>


<div class="sidebar close">

<ul class="nav-links">

<li>

<a href="/">

<i class='bx bx-home-alt bx-sm'></i>
<span class="link_name">Home</span>

</a>

</li>


<li>

<a href="<%= courseLinks[role] %>">

<i class='bx bx-folder bx-sm'></i>
<span class="link_name">Mata Kuliah</span>

</a>

</li>


<div class="logout">

<li>

<a href="/about">

<i class='bx bx-info-circle bx-sm'></i>
<span class="link_name">Info</span>

</a>

</li>

<li>

<a href="/auth/logout">

<i class='bx bx-log-out bx-sm'></i>
<span class="link_name">Logout</span>

</a>

</li>

</div>

</ul>

</div>

<div class="main">